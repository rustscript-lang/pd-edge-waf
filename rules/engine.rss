pub fn new_state(method: string, path: string, query: string, protocol: string, client_ip: string, headers: map<string>, args: map<string>, body: string) -> map<string> {
    let mut state: map<string> = {};
    state["method"] = method;
    state["path"] = path;
    state["query"] = query;
    state["protocol"] = if engine_text::starts(&protocol, "HTTP/") => { protocol } else => { "HTTP/" + protocol };
    state["client_ip"] = client_ip;
    state["request_headers"] = engine_text::encode_map(headers);
    state["args"] = engine_text::encode_map(args);
    state["request_body"] = body;
    state["response_status"] = "0";
    state["response_headers"] = "";
    state["response_body"] = "";
    state["phase"] = "1";
    state["prefilter"] = "0";
    state["paranoia"] = "1";
    state["score"] = "0";
    state["outbound_score"] = "0";
    state["blocked"] = "0";
    state["status"] = "403";
    state["skip"] = "";
    state["chain_active"] = "0";
    state["chain_matched"] = "0";
    state["matched_ids"] = "";
    state["messages"] = "";
    state["enabled_ruleset"] = "";
    state["tx.crs_setup_version"] = "428";
    state["tx.inbound_anomaly_score_threshold"] = "5";
    state["tx.outbound_anomaly_score_threshold"] = "4";
    state["tx.reporting_level"] = "4";
    state["tx.early_blocking"] = "0";
    state["tx.blocking_paranoia_level"] = "1";
    state["tx.detection_paranoia_level"] = "1";
    state["tx.sampling_percentage"] = "100";
    state["tx.critical_anomaly_score"] = "5";
    state["tx.error_anomaly_score"] = "4";
    state["tx.warning_anomaly_score"] = "3";
    state["tx.notice_anomaly_score"] = "2";
    state["tx.allowed_methods"] = "GET HEAD POST OPTIONS";
    state["tx.allowed_request_content_type"] = "|application/x-www-form-urlencoded| |multipart/form-data| |text/xml| |application/xml| |application/soap+xml| |application/json|";
    state["tx.allowed_request_content_type_charset"] = "|utf-8| |iso-8859-1| |iso-8859-15| |windows-1252|";
    state["tx.allowed_http_versions"] = "HTTP/1.0 HTTP/1.1 HTTP/2 HTTP/2.0 HTTP/3 HTTP/3.0";
    state["tx.restricted_extensions"] = ".asa .asax .ascx .bak .bat .cfg .cmd .config .conf .db .dll .ini .key .log .pem .sh .sql .sqlite .swp .tmp";
    state["tx.restricted_headers_basic"] = "content-encoding proxy lock-token content-range if x-http-method-override x-http-method x-method-override x-middleware-subrequest expect";
    state["tx.restricted_headers_extended"] = "accept-charset";
    state["tx.allow_method_override_parameter"] = "0";
    state["tx.enforce_bodyproc_urlencoded"] = "0";
    state["tx.crs_validate_utf8_encoding"] = "1";
    state["tx.crs_skip_response_analysis"] = "0";
    state["tx.enable_default_collections"] = "0";
    state["tx.inbound_anomaly_score"] = "0";
    state["tx.outbound_anomaly_score"] = "0";
    state
}

pub fn set_phase(state: map<string>, phase: int) -> map<string> {
    engine_context::ctx_set_phase(state, phase)
}

pub fn apply_action(state: map<string>, phase: int) -> map<string> {
    state
}

pub fn apply_marker(state: map<string>, marker: string) -> map<string> {
    let mut s = state;
    if engine_context::ctx_get(&s, "skip") == marker {
        s["skip"] = "";
    }
    s
}

pub fn update_target(state: map<string>, id: int, base: string, selector: string) -> map<string> {
    engine_context::ctx_update(state, id, base, selector)
}

pub fn component_signature(state: map<string>, signature: string) -> map<string> {
    let mut s = state;
    s["tx.component_signature"] = signature;
    s
}

// Match fields: id, score, disruptive, status, skip-after, message.
fn record(state: map<string>, matched: [string]) -> map<string> {
    let mut s = state;
    let phase = engine_text::number(engine_context::ctx_get(&s, "phase"), 1);
    if engine_text::number((&matched)[0], -1) >= 0 {
        let existing = engine_context::ctx_get(&s, "matched_ids");
        s["matched_ids"] = if existing == "" => { (&matched)[0] } else => { existing + "," + (&matched)[0] };
    }
    if (&matched)[5] != "" {
        s["messages"] = engine_context::ctx_get(&s, "messages") + (&matched)[5] + "\n";
    }
    let key = if phase <= 2 => { "score" } else => { "outbound_score" };
    let total = engine_text::number(engine_context::ctx_get(&s, key), 0) + engine_text::number((&matched)[1], 0);
    s[key] = total + "";
    if phase <= 2 {
        s["tx.inbound_anomaly_score"] = total + "";
    } else {
        s["tx.outbound_anomaly_score"] = total + "";
    }
    if (&matched)[2] == "1" || (phase <= 2 && total >= 5) || (phase > 2 && total >= 4) {
        s["blocked"] = "1";
        s["status"] = (&matched)[3];
    }
    if (&matched)[4] != "" {
        s["skip"] = (&matched)[4];
    }
    s
}

pub fn apply_rule(state: map<string>, id: int, chain_index: int, has_chain: bool, text: [string], target_count: int, transform_plan: int, score: int, disruptive: bool, status: int) -> map<string> {
    let mut s = state;
    let operator: int = (target_count % 16384) / 64;
    if engine_context::ctx_get(&s, "blocked") != "1" && engine_context::ctx_get(&s, "skip") == "" {
    let mut matched = false;
    if chain_index == 0 || engine_context::ctx_get(&s, "chain_matched") == "1" {
        let values: [string] = engine_context::ctx_targets(&s, &text, target_count, id);
        for i in 0..values.length {
            let transformed: string = engine_text::transforms((&values)[i], transform_plan);
            if engine_operators::op_matches(&s, operator, &(&text)[0], transformed) {
                matched = true;
                break;
            }
        }
    }
    if chain_index == 0 && has_chain {
        s["chain_active"] = "1";
        s["chain_matched"] = if matched => { "1" } else => { "0" };
        s["chain_id"] = id + "";
        s["chain_score"] = score + "";
        s["chain_disruptive"] = if disruptive => { "1" } else => { "0" };
        s["chain_status"] = status + "";
        s["chain_skip"] = (&text)[1];
        s["chain_message"] = (&text)[2];
    } else if chain_index > 0 {
        let ok = engine_context::ctx_get(&s, "chain_matched") == "1" && matched;
        s["chain_matched"] = if ok => { "1" } else => { "0" };
        if !has_chain {
            if engine_context::ctx_get(&s, "chain_active") == "1" && ok {
                s = record(s, [
                    engine_context::ctx_get(&s, "chain_id"),
                    engine_context::ctx_get(&s, "chain_score"),
                    engine_context::ctx_get(&s, "chain_disruptive"),
                    engine_context::ctx_get(&s, "chain_status"),
                    engine_context::ctx_get(&s, "chain_skip"),
                    engine_context::ctx_get(&s, "chain_message")
                ]);
            }
            s["chain_active"] = "0";
            s["chain_matched"] = "0";
        }
    } else if matched {
        s = record(s, [id + "", score + "", if disruptive => { "1" } else => { "0" }, status + "", (&text)[1], (&text)[2]]);
    }
    }
    s
}

pub fn apply_rule_619(state: map<string>, id: int, chain_index: int, has_chain: bool, text: [string], target_count: int, transform_plan: int, score: int, disruptive: bool, status: int) -> map<string> {
    let mut s = state;
    if engine_context::ctx_get(&s, "blocked") != "1" && engine_context::ctx_get(&s, "skip") == "" {
    let mut matched = false;
    if chain_index == 0 || engine_context::ctx_get(&s, "chain_matched") == "1" {
        let values: [string] = engine_context::ctx_targets(&s, &text, target_count, id);
        for i in 0..values.length {
            let mut transformed: string = (&values)[i];
            if engine_text::contains(&transformed, "%") || engine_text::contains(&transformed, "+") {
                transformed = string_replace_literal(transformed, "%27", "'");
                transformed = string_replace_literal(transformed, "%22", "\"");
                transformed = string_replace_literal(transformed, "%20", " ");
                transformed = string_replace_literal(transformed, "%3d", "=");
                transformed = string_replace_literal(transformed, "%3D", "=");
                transformed = string_replace_literal(transformed, "%3c", "<");
                transformed = string_replace_literal(transformed, "%3C", "<");
                transformed = string_replace_literal(transformed, "%3e", ">");
                transformed = string_replace_literal(transformed, "%3E", ">");
                transformed = string_replace_literal(transformed, "+", " ");
            }
            if transform_plan == 18027 && engine_text::contains(&transformed, "/*") {
                transformed = re::replace("(?s)/\\*.*?\\*/", transformed, " ");
            } else if (transform_plan == 511627 || transform_plan == 15979) && engine_text::contains(&transformed, "\0") {
                transformed = string_replace_literal(transformed, "\0", "");
            } else if transform_plan == 17003 {
                transformed = re::replace("\\s+", transformed, "");
            }
            if engine_operators::op_matches(&s, (target_count % 16384) / 64, &(&text)[0], transformed) {
                matched = true;
                break;
            }
        }
    }
    if id == -1 {
        s["prefilter"] = if matched => { "1" } else => { "0" };
    } else if chain_index == 0 && has_chain {
        s["chain_active"] = "1";
        s["chain_matched"] = if matched => { "1" } else => { "0" };
        s["chain_id"] = id + "";
        s["chain_score"] = score + "";
        s["chain_disruptive"] = if disruptive => { "1" } else => { "0" };
        s["chain_status"] = status + "";
        s["chain_skip"] = (&text)[1];
        s["chain_message"] = (&text)[2];
    } else if chain_index > 0 {
        let ok = engine_context::ctx_get(&s, "chain_matched") == "1" && matched;
        s["chain_matched"] = if ok => { "1" } else => { "0" };
        if !has_chain {
            if engine_context::ctx_get(&s, "chain_active") == "1" && ok {
                s = record(s, [
                    engine_context::ctx_get(&s, "chain_id"),
                    engine_context::ctx_get(&s, "chain_score"),
                    engine_context::ctx_get(&s, "chain_disruptive"),
                    engine_context::ctx_get(&s, "chain_status"),
                    engine_context::ctx_get(&s, "chain_skip"),
                    engine_context::ctx_get(&s, "chain_message")
                ]);
            }
            s["chain_active"] = "0";
            s["chain_matched"] = "0";
        }
    } else if matched {
        s = record(s, [id + "", score + "", if disruptive => { "1" } else => { "0" }, status + "", (&text)[1], (&text)[2]]);
    }
    }
    s
}

