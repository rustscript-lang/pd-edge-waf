pub fn category_enabled(state: map<string>, category: string) -> bool {
    let enabled = engine_context::ctx_get(&state, "enabled_ruleset");
    engine_context::ctx_get(&state, "blocked") != "1" && (enabled == "" || engine_text::contains(" " + enabled + " ", " " + category + " "))
}
