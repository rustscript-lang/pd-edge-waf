// Match fields: id, score, disruptive, status, skip-after, message.
pub fn record_rule_match(state: map<string>, matched: [string]) -> map<string> {
    let mut s = state;
    let phase = number(ctx_get(&s, "phase"), 1);
    if number((&matched)[0], -1) >= 0 {
        let existing = ctx_get(&s, "matched_ids");
        s["matched_ids"] = if existing == "" => { (&matched)[0] } else => { existing + "," + (&matched)[0] };
    }
    if (&matched)[5] != "" {
        s["messages"] = ctx_get(&s, "messages") + (&matched)[5] + "\n";
    }
    let key = if phase <= 2 => { "score" } else => { "outbound_score" };
    let total = number(ctx_get(&s, key), 0) + number((&matched)[1], 0);
    s[key] = total + "";
    if phase <= 2 {
        s["tx.inbound_anomaly_score"] = total + "";
        s["tx.blocking_inbound_anomaly_score"] = total + "";
        s["tx.detection_inbound_anomaly_score"] = total + "";
    } else {
        s["tx.outbound_anomaly_score"] = total + "";
        s["tx.blocking_outbound_anomaly_score"] = total + "";
        s["tx.detection_outbound_anomaly_score"] = total + "";
    }
    if (&matched)[2] == "1" {
        s["blocked"] = "1";
        s["status"] = (&matched)[3];
    }
    if (&matched)[4] != "" {
        s["skip"] = (&matched)[4];
    }
    s
}

pub fn apply_detection_paranoia_skip(state: map<string>, id: int, threshold: int, marker: string) -> map<string> {
    let mut s = state;
    if ctx_get(&s, "blocked") != "1"
        && ctx_get(&s, "skip") == ""
        && number(ctx_get(&s, "tx.detection_paranoia_level"), 1) < threshold {
        s = record_rule_match(s, [id + "", "0", "0", "403", marker, ""]);
    }
    s
}

pub fn apply_rule(state: map<string>, id: int, chain_index: int, has_chain: bool, text: [string], target_count: int, transform_plan: int, score: int, disruptive: bool, status: int) -> map<string> {
    let mut s = state;
    let operator: int = (target_count % 16384) / 64;
    if ctx_get(&s, "blocked") != "1" && ctx_get(&s, "skip") == "" {
    let mut matched = false;
    if chain_index == 0 || ctx_get(&s, "chain_matched") == "1" {
        let values: [string] = ctx_targets(&s, &text, target_count, id);
        for i in 0..values.length {
            let transformed: string = transforms((&values)[i], transform_plan);
            if op_matches(&s, operator, &(&text)[0], transformed) {
                matched = true;
                break;
            }
        }
    }
    if id == -1 {
        s["prefilter"] = if matched => { "1" } else => { "0" };
    } else if chain_index == 0 && has_chain {
        s["chain_active"] = "1";
        s["chain_matched"] = if matched => { "1" } else => { "0" };
        s["chain_id"] = id + "";
        s["chain_score"] = score + "";
        s["chain_disruptive"] = if disruptive => { "1" } else => { "0" };
        s["chain_status"] = status + "";
        s["chain_skip"] = (&text)[1];
        s["chain_message"] = (&text)[2];
    } else if chain_index > 0 {
        let ok = ctx_get(&s, "chain_matched") == "1" && matched;
        s["chain_matched"] = if ok => { "1" } else => { "0" };
        if !has_chain {
            if ctx_get(&s, "chain_active") == "1" && ok {
                s = record_rule_match(s, [
                    ctx_get(&s, "chain_id"),
                    ctx_get(&s, "chain_score"),
                    ctx_get(&s, "chain_disruptive"),
                    ctx_get(&s, "chain_status"),
                    ctx_get(&s, "chain_skip"),
                    ctx_get(&s, "chain_message")
                ]);
            }
            s["chain_active"] = "0";
            s["chain_matched"] = "0";
        }
    } else if matched {
        if id == 200000 {
            s["reqbody_processor"] = "XML";
        } else if id == 200001 {
            s["reqbody_processor"] = "JSON";
        }
        s = record_rule_match(s, [id + "", score + "", if disruptive => { "1" } else => { "0" }, status + "", (&text)[1], (&text)[2]]);
    }
    }
    s
}

pub fn apply_rule_619(state: map<string>, id: int, chain_index: int, has_chain: bool, text: [string], target_count: int, transform_plan: int, score: int, disruptive: bool, status: int) -> map<string> {
    let mut s = state;
    if ctx_get(&s, "blocked") != "1" && ctx_get(&s, "skip") == "" {
    let mut matched = false;
    if chain_index == 0 || ctx_get(&s, "chain_matched") == "1" {
        let values: [string] = ctx_targets(&s, &text, target_count, id);
        for i in 0..values.length {
            let mut transformed: string = (&values)[i];
            if string_contains(&transformed, "%") || string_contains(&transformed, "+") {
                transformed = string_replace_literal(transformed, "%27", "'");
                transformed = string_replace_literal(transformed, "%22", "\"");
                transformed = string_replace_literal(transformed, "%20", " ");
                transformed = string_replace_literal(transformed, "%3d", "=");
                transformed = string_replace_literal(transformed, "%3D", "=");
                transformed = string_replace_literal(transformed, "%3c", "<");
                transformed = string_replace_literal(transformed, "%3C", "<");
                transformed = string_replace_literal(transformed, "%3e", ">");
                transformed = string_replace_literal(transformed, "%3E", ">");
                transformed = string_replace_literal(transformed, "+", " ");
            }
            if transform_plan == 18027 && string_contains(&transformed, "/*") {
                transformed = re::replace("(?s)/\\*.*?\\*/", transformed, " ");
            } else if (transform_plan == 511627 || transform_plan == 15979) && string_contains(&transformed, "\0") {
                transformed = string_replace_literal(transformed, "\0", "");
            } else if transform_plan == 17003 {
                transformed = re::replace("\\s+", transformed, "");
            }
            if op_matches(&s, (target_count % 16384) / 64, &(&text)[0], transformed) {
                matched = true;
                break;
            }
        }
    }
    if id == -1 {
        s["prefilter"] = if matched => { "1" } else => { "0" };
    } else if chain_index == 0 && has_chain {
        s["chain_active"] = "1";
        s["chain_matched"] = if matched => { "1" } else => { "0" };
        s["chain_id"] = id + "";
        s["chain_score"] = score + "";
        s["chain_disruptive"] = if disruptive => { "1" } else => { "0" };
        s["chain_status"] = status + "";
        s["chain_skip"] = (&text)[1];
        s["chain_message"] = (&text)[2];
    } else if chain_index > 0 {
        let ok = ctx_get(&s, "chain_matched") == "1" && matched;
        s["chain_matched"] = if ok => { "1" } else => { "0" };
        if !has_chain {
            if ctx_get(&s, "chain_active") == "1" && ok {
                s = record_rule_match(s, [
                    ctx_get(&s, "chain_id"),
                    ctx_get(&s, "chain_score"),
                    ctx_get(&s, "chain_disruptive"),
                    ctx_get(&s, "chain_status"),
                    ctx_get(&s, "chain_skip"),
                    ctx_get(&s, "chain_message")
                ]);
            }
            s["chain_active"] = "0";
            s["chain_matched"] = "0";
        }
    } else if matched {
        s = record_rule_match(s, [id + "", score + "", if disruptive => { "1" } else => { "0" }, status + "", (&text)[1], (&text)[2]]);
    }
    }
    s
}

pub fn apply_rule_decode_comments(state: map<string>, id: int, chain_index: int, has_chain: bool, text: [string], target_count: int, transform_plan: int, score: int, disruptive: bool, status: int) -> map<string> {
    let mut s = state;
    if ctx_get(&s, "blocked") != "1" && ctx_get(&s, "skip") == "" {
    let mut matched = false;
    if chain_index == 0 || ctx_get(&s, "chain_matched") == "1" {
        let values: [string] = ctx_targets(&s, &text, target_count, id);
        for i in 0..values.length {
            let mut transformed: string = (&values)[i];
            if string_contains(&transformed, "%") || string_contains(&transformed, "+") {
                transformed = string_replace_literal(transformed, "%27", "'");
                transformed = string_replace_literal(transformed, "%22", "\"");
                transformed = string_replace_literal(transformed, "%20", " ");
                transformed = string_replace_literal(transformed, "%3d", "=");
                transformed = string_replace_literal(transformed, "%3D", "=");
                transformed = string_replace_literal(transformed, "%3c", "<");
                transformed = string_replace_literal(transformed, "%3C", "<");
                transformed = string_replace_literal(transformed, "%3e", ">");
                transformed = string_replace_literal(transformed, "%3E", ">");
                transformed = string_replace_literal(transformed, "+", " ");
            }
            if string_contains(&transformed, "/*") {
                transformed = re::replace("(?s)/\\*.*?\\*/", transformed, " ");
            }
            if op_matches(&s, (target_count % 16384) / 64, &(&text)[0], transformed) {
                matched = true;
                break;
            }
        }
    }
    if chain_index == 0 && has_chain {
        s["chain_active"] = "1";
        s["chain_matched"] = if matched => { "1" } else => { "0" };
        s["chain_id"] = id + "";
        s["chain_score"] = score + "";
        s["chain_disruptive"] = if disruptive => { "1" } else => { "0" };
        s["chain_status"] = status + "";
        s["chain_skip"] = (&text)[1];
        s["chain_message"] = (&text)[2];
    } else if chain_index > 0 {
        let ok = ctx_get(&s, "chain_matched") == "1" && matched;
        s["chain_matched"] = if ok => { "1" } else => { "0" };
        if !has_chain {
            if ctx_get(&s, "chain_active") == "1" && ok {
                s = record_rule_match(s, [
                    ctx_get(&s, "chain_id"),
                    ctx_get(&s, "chain_score"),
                    ctx_get(&s, "chain_disruptive"),
                    ctx_get(&s, "chain_status"),
                    ctx_get(&s, "chain_skip"),
                    ctx_get(&s, "chain_message")
                ]);
            }
            s["chain_active"] = "0";
            s["chain_matched"] = "0";
        }
    } else if matched {
        s = record_rule_match(s, [id + "", score + "", if disruptive => { "1" } else => { "0" }, status + "", (&text)[1], (&text)[2]]);
    }
    }
    s
}

pub fn category_enabled(state: map<string>, category: string) -> bool {
    let enabled = ctx_get(&state, "enabled_ruleset");
    ctx_get(&state, "blocked") != "1" && (enabled == "" || string_contains(" " + enabled + " ", " " + category + " "))
}
