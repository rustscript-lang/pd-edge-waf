    state["method"] = method;
    state["path"] = path;
    state["query"] = query;
    state["protocol"] = if starts(&protocol, "HTTP/") => { protocol } else => { "HTTP/" + protocol };
    state["client_ip"] = client_ip;
    state["request_headers"] = encode_map(headers);
    state["args"] = encode_map(args);
