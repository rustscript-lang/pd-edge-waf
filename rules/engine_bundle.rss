use re;
use bytes;

// bundled from engine_text.rss

pub fn lower(value: string) -> string { string_lower_ascii(value) }
pub fn contains(value: string, needle: string) -> bool { string_contains(value, needle) }
pub fn replace(value: string, needle: string, replacement: string) -> string { string_replace_literal(value, needle, replacement) }
pub fn starts(value: string, prefix: string) -> bool { prefix.length <= value.length && (&value)[0:prefix.length] == prefix }
pub fn ends(value: string, suffix: string) -> bool { suffix.length <= value.length && (&value)[(value.length - suffix.length):value.length] == suffix }
pub fn number(value: string, fallback: int) -> int {
 let digits = "0123456789"; let mut out = 0; let mut valid = value.length > 0;
 for i in 0..value.length { let ch = (&value)[i:(i + 1)]; let mut digit = -1; for j in 0..10 { if ch == (&digits)[j:(j + 1)] { digit = j; break; } } if digit < 0 { valid = false; break; } out = out * 10 + digit; }
 if valid => { out } else => { fallback }
}
pub fn encode_map(values: map<string>) -> string {
 let keys = (&values).keys; let mut out = "";
 for i in 0..keys.length { let key: string = (&keys)[i]; out = out + key + "=" + (&values)[key] + "\n"; }
 out
}
pub fn transforms(value: string, encoded: int) -> string {
 let mut out = value;
 let mut plan = encoded;
 while plan > 0 {
  let op = plan % 32;
  plan = plan / 32;
  if op == 4 || op == 8 || op == 19 { out = replace(out, "%27", "'"); out = replace(out, "%22", "\""); out = replace(out, "%20", " "); out = replace(out, "%3d", "="); out = replace(out, "%3D", "="); out = replace(out, "%3c", "<"); out = replace(out, "%3C", "<"); out = replace(out, "%3e", ">"); out = replace(out, "%3E", ">"); out = replace(out, "+", " "); }
  else if op == 7 { out = replace(out, "&lt;", "<"); out = replace(out, "&gt;", ">"); out = replace(out, "&quot;", "\""); out = replace(out, "&#39;", "'"); }
  else if op == 15 { out = replace(out, "\0", ""); }
  else if op == 16 { out = re::replace("\\s+", out, ""); }
  else if op == 3 { out = re::replace("\\s+", out, " "); }
  else if op == 17 { out = re::replace("(?s)/\\*.*?\\*/", out, " "); }
  else if op == 12 || op == 13 { out = replace(out, "\\", "/"); }
  else if op == 2 { out = replace(out, "\\", ""); out = lower(out); }
  else if op == 10 { out = lower(out); }
  else if op == 9 { out = out.length + ""; }
  else if op == 1 || op == 5 || op == 6 || op == 11 || op == 14 || op == 18 || op == 20 { out = out; }
 }
 out
}

// bundled from engine_context.rss

pub fn ctx_get(state: map<string>, key: string) -> string {
 if (&state).has(&key) => { (&state)[key] } else => { "" }
}
pub fn ctx_set_phase(state: map<string>, phase: int) -> map<string> {
 let mut s = state; s["phase"] = phase + ""; s["skip"] = ""; s["chain_active"] = "0"; s["chain_matched"] = "0"; s
}
pub fn normalized_target_base(raw: string) -> string {
 let positive: string = if starts(&raw, "!") => { (&raw)[1:raw.length] } else => { raw };
 if starts(&positive, "&") => { (&positive)[1:positive.length] } else => { positive }
}
pub fn selector_matches(selector: string, name: string) -> bool {
 selector == "" || lower(&name) == lower(&selector) || (selector.length > 2 && (&selector)[0:1] == "/" && re::match((&selector)[1:(selector.length - 1)], &name))
}
pub fn descriptor_excludes(text: [string], target_count: int, base: string, name: string) -> bool {
 let mut excluded: bool = false; let mut i: int = 0;
 while i < target_count { let position: int = 4 + i * 3; let raw_base: string = (&text)[position]; let excluded_selector: string = (&text)[position + 1]; if starts(&raw_base, "!") && normalized_target_base(raw_base) == base && (excluded_selector == "" || (name != "" && selector_matches(excluded_selector, name))) { excluded = true; break; } i = i + 1; }
 excluded
}
pub fn dynamic_descriptor_excludes(bases: [string], selectors: [string], base: string, name: string) -> bool {
 let mut excluded: bool = false; let mut i: int = 0;
 while i < bases.length && i < selectors.length { let excluded_base: string = (&bases)[i]; let excluded_selector: string = (&selectors)[i]; if excluded_base == base && (excluded_selector == "" || (name != "" && selector_matches(excluded_selector, name))) { excluded = true; break; } i = i + 1; }
 excluded
}
pub fn pair_values(encoded: string, selector: string, names: bool, text: [string], target_count: int, base: string, dynamic_bases: [string], dynamic_selectors: [string]) -> [string] {
 let lines: [string] = string_split_literal(encoded, "\n"); let mut out: [string] = [];
 for i in 0..lines.length { let line: string = (&lines)[i]; let pieces: [string] = string_split_literal(line, "=");
  if pieces.length > 0 { let key: string = (&pieces)[0]; if selector_matches(selector, &key) && !descriptor_excludes(&text, target_count, &base, &key) && (dynamic_bases.length == 0 || !dynamic_descriptor_excludes(&dynamic_bases, &dynamic_selectors, &base, &key)) { out[out.length] = if names => { key } else if pieces.length > 1 => { (&pieces)[1] } else => { "" }; } }
 }
 out
}
pub fn one(state: map<string>, raw_base: string, name: string, text: [string], target_count: int, dynamic_bases: [string], dynamic_selectors: [string]) -> [string] {
 let counted: bool = starts(&raw_base, "&"); let base: string = normalized_target_base(raw_base); let mut out: [string] = [];
 if base == "REQUEST_METHOD" { out = [ctx_get(&state, "method")]; }
 else if base == "REQUEST_FILENAME" || base == "REQUEST_URI" || base == "REQUEST_URI_RAW" || base == "REQUEST_BASENAME" { out = [ctx_get(&state, "path")]; }
 else if base == "QUERY_STRING" { out = [ctx_get(&state, "query")]; }
 else if base == "REQUEST_BODY" || base == "XML" || base == "FILES" || base == "FILES_NAMES" || base == "MULTIPART_PART_HEADERS" { out = [ctx_get(&state, "request_body")]; }
 else if base == "REQUEST_BODY_LENGTH" { out = [ctx_get(&state, "request_body").length + ""]; }
 else if base == "REQUEST_PROTOCOL" { out = [ctx_get(&state, "protocol")]; }
 else if base == "REQUEST_LINE" { out = [ctx_get(&state, "method") + " " + ctx_get(&state, "path") + (if ctx_get(&state, "query") == "" => { "" } else => { "?" + ctx_get(&state, "query") }) + " " + ctx_get(&state, "protocol")]; }
 else if base == "REMOTE_ADDR" { out = [ctx_get(&state, "client_ip")]; }
 else if base == "REQUEST_HEADERS" { out = pair_values(ctx_get(&state, "request_headers"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "REQUEST_HEADERS_NAMES" { out = pair_values(ctx_get(&state, "request_headers"), name, true, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "REQUEST_COOKIES" { out = pair_values(ctx_get(&state, "cookies"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "REQUEST_COOKIES_NAMES" { out = pair_values(ctx_get(&state, "cookies"), name, true, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "ARGS" || base == "ARGS_GET" { out = pair_values(ctx_get(&state, "args"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "ARGS_NAMES" || base == "ARGS_GET_NAMES" { out = pair_values(ctx_get(&state, "args"), name, true, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "RESPONSE_BODY" { out = [ctx_get(&state, "response_body")]; }
 else if base == "RESPONSE_STATUS" { out = [ctx_get(&state, "response_status")]; }
 else if base == "RESPONSE_HEADERS" { out = pair_values(ctx_get(&state, "response_headers"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "TX" { let tx_key: string = "tx." + lower(&name); if !starts(&name, "/") && (&state).has(&tx_key) { out = [(&state)[tx_key]]; } }
 if counted => { [out.length + ""] } else => { out }
}
pub fn ctx_targets(state: map<string>, text: [string], target_count: int, id: int) -> [string] {
 let mut out: [string] = []; let id_text: string = id + ""; let base_key: string = "exclude_base." + id_text; let has_dynamic: bool = (&state).has(&base_key); let encoded_bases: string = if has_dynamic => { (&state)[base_key] } else => { "" }; let encoded_selectors: string = if has_dynamic => { ctx_get(&state, "exclude_selector." + id_text) } else => { "" }; let dynamic_bases: [string] = if has_dynamic => { string_split_literal(encoded_bases, "\n") } else => { [] }; let dynamic_selectors: [string] = if has_dynamic => { string_split_literal(encoded_selectors, "\n") } else => { [] }; let mut i: int = 0;
 while i < target_count { let position: int = 4 + i * 3; let raw_base: string = (&text)[position]; let name: string = (&text)[position + 1]; let base: string = normalized_target_base(&raw_base); if !starts(&raw_base, "!") && !descriptor_excludes(&text, target_count, &base, &name) && (!has_dynamic || !dynamic_descriptor_excludes(&dynamic_bases, &dynamic_selectors, &base, &name)) { let values: [string] = one(&state, raw_base, name, &text, target_count, &dynamic_bases, &dynamic_selectors); for j in 0..values.length { out[out.length] = (&values)[j]; } } i = i + 1; }
 out
}
pub fn ctx_update(state: map<string>, id: int, raw_base: string, selector: string) -> map<string> {
 let mut s = state; let id_text: string = id + ""; let base_key: string = "exclude_base." + id_text; let selector_key: string = "exclude_selector." + id_text;
 s[base_key] = ctx_get(&s, &base_key) + "\n" + normalized_target_base(raw_base) + "\n";
 s[selector_key] = ctx_get(&s, &selector_key) + "\n" + selector + "\n";
 s
}

// bundled from engine_operators.rss
pub fn op_expand(state: map<string>, value: string) -> string { let mut out = value; let keys = (&state).keys; for i in 0..keys.length { let key: string = (&keys)[i]; if starts(&key, "tx.") { out = replace(out, "%{" + key + "}", (&state)[key]); } } out }
pub fn sqli(value: string) -> bool { let text: string = lower(value); (contains(&text, " union ") && contains(&text, "select")) || contains(&text, "' or '") || contains(&text, "'or 1=1") || contains(&text, " or 1=1") || contains(&text, "sleep(") || contains(&text, "benchmark(") || contains(&text, "information_schema") }
pub fn xss(value: string) -> bool { let text: string = lower(value); contains(&text, "<script") || contains(&text, "javascript:") || contains(&text, "onerror=") || contains(&text, "onload=") || (contains(&text, "<svg") && contains(&text, "on")) }
pub fn phrase(pattern: string, value: string) -> bool { let phrases: [string] = if contains(&pattern, "\n") => { string_split_literal(pattern, "\n") } else => { string_split_literal(pattern, " ") }; let haystack: string = lower(value); let mut found = false; for i in 0..phrases.length { let item: string = lower((&phrases)[i]); if item != "" && contains(&haystack, item) { found = true; break; } } found }
pub fn op_matches(state: map<string>, operator: string, argument: string, value: string) -> bool {
 let negated: bool = starts(&operator, "!"); let name: string = if negated => { (&operator)[1:operator.length] } else => { operator }; let expected: string = op_expand(&state, argument); let mut raw: bool = false;
 if name == "@rx" { raw = re::match(&expected, &value); }
 else if name == "@pm" || name == "@pmFromFile" { raw = phrase(&expected, &value); }
 else if name == "@detectSQLi" { raw = sqli(&value); }
 else if name == "@detectXSS" { raw = xss(&value); }
 else if name == "@contains" { raw = contains(&value, &expected); }
 else if name == "@beginsWith" { raw = starts(&value, &expected); }
 else if name == "@endsWith" { raw = ends(&value, &expected); }
 else if name == "@streq" { raw = value == expected; }
 else if name == "@within" { raw = contains(" " + expected + " ", " " + value + " "); }
 else if name == "@eq" { raw = number(&value, 0) == number(&expected, 0); }
 else if name == "@lt" { raw = number(&value, 0) < number(&expected, 0); }
 else if name == "@ge" { raw = number(&value, 0) >= number(&expected, 0); }
 else if name == "@gt" { raw = number(&value, 0) > number(&expected, 0); }
 else if name == "@validateUrlEncoding" { raw = !re::match("%(?:[^0-9A-Fa-f]|.[^0-9A-Fa-f]|$)", &value); }
 else if name == "@validateUtf8Encoding" || name == "@validateByteRange" { raw = false; }
 else if name == "@unconditionalMatch" { raw = true; }
 else if name == "@ipMatch" { raw = phrase(replace(&expected, ",", "\n"), &value); }
 if negated => { !raw } else => { raw }
}

