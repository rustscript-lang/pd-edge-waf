use re;
use engine_text;
pub fn op_expand(state: map<string>, value: string) -> string {
 let mut out: string = value;
 if string_contains(&out, "%{") { let keys: [string] = (&state).keys; for i in 0..keys.length { let key: string = (&keys)[i]; if engine_text::starts(&key, "tx.") { out = string_replace_literal(out, "%{" + key + "}", (&state)[key]); } } }
 out
}
pub fn sqli(value: string) -> bool { let text: string = string_lower_ascii(value); (string_contains(&text, " union ") && string_contains(&text, "select")) || string_contains(&text, "' or '") || string_contains(&text, "'or 1=1") || string_contains(&text, " or 1=1") || string_contains(&text, "sleep(") || string_contains(&text, "benchmark(") || string_contains(&text, "information_schema") }
pub fn xss(value: string) -> bool { let text: string = string_lower_ascii(value); string_contains(&text, "<script") || string_contains(&text, "javascript:") || string_contains(&text, "onerror=") || string_contains(&text, "onload=") || (string_contains(&text, "<svg") && string_contains(&text, "on")) }
pub fn phrase(pattern: string, value: string) -> bool { let phrases: [string] = if string_contains(&pattern, "\n") => { string_split_literal(pattern, "\n") } else => { string_split_literal(pattern, " ") }; let haystack: string = string_lower_ascii(value); let mut found = false; for i in 0..phrases.length { let item: string = string_lower_ascii((&phrases)[i]); if item != "" && string_contains(&haystack, item) { found = true; break; } } found }
pub fn op_matches(state: map<string>, operator: string, argument: string, value: string) -> bool {
 let negated: bool = engine_text::starts(&operator, "!"); let name: string = if negated => { (&operator)[1:operator.length] } else => { operator }; let expected: string = op_expand(&state, argument); let mut raw: bool = false;
 if name == "@rx" { raw = re::match(&expected, &value); }
 else if name == "@pm" || name == "@pmFromFile" { raw = phrase(&expected, &value); }
 else if name == "@detectSQLi" { raw = sqli(&value); }
 else if name == "@detectXSS" { raw = xss(&value); }
 else if name == "@contains" { raw = string_contains(&value, &expected); }
 else if name == "@beginsWith" { raw = engine_text::starts(&value, &expected); }
 else if name == "@endsWith" { raw = engine_text::ends(&value, &expected); }
 else if name == "@streq" { raw = value == expected; }
 else if name == "@within" { raw = string_contains(" " + expected + " ", " " + value + " "); }
 else if name == "@eq" { raw = engine_text::number(&value, 0) == engine_text::number(&expected, 0); }
 else if name == "@lt" { raw = engine_text::number(&value, 0) < engine_text::number(&expected, 0); }
 else if name == "@ge" { raw = engine_text::number(&value, 0) >= engine_text::number(&expected, 0); }
 else if name == "@gt" { raw = engine_text::number(&value, 0) > engine_text::number(&expected, 0); }
 else if name == "@validateUrlEncoding" { raw = !re::match("%(?:[^0-9A-Fa-f]|.[^0-9A-Fa-f]|$)", &value); }
 else if name == "@validateUtf8Encoding" || name == "@validateByteRange" { raw = false; }
 else if name == "@unconditionalMatch" { raw = true; }
 else if name == "@ipMatch" { raw = phrase(string_replace_literal(&expected, ",", "\n"), &value); }
 if negated => { !raw } else => { raw }
}
