use re;
use engine_text;
pub fn op_expand(state: map<string>, value: string) -> string {
 let mut out: string = value;
 if engine_text::contains(&out, "%{") { let keys: [string] = (&state).keys; for i in 0..keys.length { let key: string = (&keys)[i]; if engine_text::starts(&key, "tx.") { out = engine_text::replace(out, "%{" + key + "}", (&state)[key]); } } }
 out
}
pub fn sqli(value: string) -> bool { let text: string = engine_text::lower(value); (engine_text::contains(&text, " union ") && engine_text::contains(&text, "select")) || engine_text::contains(&text, "' or '") || engine_text::contains(&text, "'or 1=1") || engine_text::contains(&text, " or 1=1") || engine_text::contains(&text, "sleep(") || engine_text::contains(&text, "benchmark(") || engine_text::contains(&text, "information_schema") }
pub fn xss(value: string) -> bool { let text: string = engine_text::lower(value); engine_text::contains(&text, "<script") || engine_text::contains(&text, "javascript:") || engine_text::contains(&text, "onerror=") || engine_text::contains(&text, "onload=") || (engine_text::contains(&text, "<svg") && engine_text::contains(&text, "on")) }
pub fn phrase(pattern: string, value: string) -> bool { let phrases: [string] = if engine_text::contains(&pattern, "\n") => { string_split_literal(pattern, "\n") } else => { string_split_literal(pattern, " ") }; let haystack: string = engine_text::lower(value); let mut found = false; for i in 0..phrases.length { let item: string = engine_text::lower((&phrases)[i]); if item != "" && engine_text::contains(&haystack, item) { found = true; break; } } found }
pub fn op_matches(state: map<string>, operator: int, argument: string, value: string) -> bool {
 let expected = if operator >= 128 => { operator = operator - 128; if (&state).has(&argument) => { "." + (&state)[argument] } else => { ".%{" + argument + "}" } } else if operator >= 64 => { operator = operator - 64; if (&state).has(&argument) => { (&state)[argument] } else => { "%{" + argument + "}" } } else => { op_expand(&state, argument) }; let negated: bool = operator >= 32; let code: int = if negated => { operator - 32 } else => { operator }; let mut raw: bool = false;
 if code == 1 { raw = re::match(&expected, &value); }
 else if code == 2 { raw = phrase(&expected, &value); }
 else if code == 3 { raw = sqli(&value); }
 else if code == 4 { raw = xss(&value); }
 else if code == 5 { raw = engine_text::contains(&value, &expected); }
 else if code == 6 { raw = engine_text::starts(&value, &expected); }
 else if code == 7 { raw = engine_text::ends(&value, &expected); }
 else if code == 8 { raw = value == expected; }
 else if code == 9 { raw = engine_text::contains(" " + expected + " ", " " + value + " "); }
 else if code == 10 { raw = engine_text::number(&value, 0) == engine_text::number(&expected, 0); }
 else if code == 11 { raw = engine_text::number(&value, 0) < engine_text::number(&expected, 0); }
 else if code == 12 { raw = engine_text::number(&value, 0) >= engine_text::number(&expected, 0); }
 else if code == 13 { raw = engine_text::number(&value, 0) > engine_text::number(&expected, 0); }
 else if code == 14 { raw = !re::match("%(?:[^0-9A-Fa-f]|.[^0-9A-Fa-f]|$)", &value); }
 else if code == 15 || code == 16 { raw = false; }
 else if code == 17 { raw = true; }
 else if code == 18 { raw = phrase(engine_text::replace(&expected, ",", "\n"), &value); }
 if negated => { !raw } else => { raw }
}
