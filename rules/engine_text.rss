use re;

pub fn lower(value: string) -> string { string_lower_ascii(value) }
pub fn contains(value: string, needle: string) -> bool { string_contains(value, needle) }
pub fn replace(value: string, needle: string, replacement: string) -> string { string_replace_literal(value, needle, replacement) }
pub fn starts(value: string, prefix: string) -> bool { prefix.length <= value.length && (&value)[0:prefix.length] == prefix }
pub fn ends(value: string, suffix: string) -> bool { suffix.length <= value.length && (&value)[(value.length - suffix.length):value.length] == suffix }
pub fn number(value: string, fallback: int) -> int {
 let digits = "0123456789"; let mut out = 0; let mut valid = value.length > 0;
 for i in 0..value.length { let ch = (&value)[i:(i + 1)]; let mut digit = -1; for j in 0..10 { if ch == (&digits)[j:(j + 1)] { digit = j; break; } } if digit < 0 { valid = false; break; } out = out * 10 + digit; }
 if valid => { out } else => { fallback }
}
pub fn encode_map(values: map<string>) -> string {
 let keys = (&values).keys; let mut out = "";
 for i in 0..keys.length { let key: string = (&keys)[i]; out = out + key + "=" + (&values)[key] + "\n"; }
 out
}
pub fn transforms(value: string, encoded: int) -> string {
 let mut out = value;
 let mut plan = encoded;
 while plan > 0 {
  let op = plan % 32;
  plan = plan / 32;
  if op == 4 || op == 8 || op == 19 { out = string_replace_literal(out, "%27", "'"); out = string_replace_literal(out, "%22", "\""); out = string_replace_literal(out, "%20", " "); out = string_replace_literal(out, "%3d", "="); out = string_replace_literal(out, "%3D", "="); out = string_replace_literal(out, "%3c", "<"); out = string_replace_literal(out, "%3C", "<"); out = string_replace_literal(out, "%3e", ">"); out = string_replace_literal(out, "%3E", ">"); out = string_replace_literal(out, "+", " "); }
  else if op == 7 { out = string_replace_literal(out, "&lt;", "<"); out = string_replace_literal(out, "&gt;", ">"); out = string_replace_literal(out, "&quot;", "\""); out = string_replace_literal(out, "&#39;", "'"); }
  else if op == 15 { out = string_replace_literal(out, "\0", ""); }
  else if op == 16 { out = re::replace("\\s+", out, ""); }
  else if op == 3 { out = re::replace("\\s+", out, " "); }
  else if op == 17 { out = re::replace("(?s)/\\*.*?\\*/", out, " "); }
  else if op == 12 || op == 13 { out = string_replace_literal(out, "\\", "/"); }
  else if op == 2 { out = string_replace_literal(out, "\\", ""); out = string_lower_ascii(out); }
  else if op == 10 { out = string_lower_ascii(out); }
  else if op == 9 { out = out.length + ""; }
  else if op == 1 || op == 5 || op == 6 || op == 11 || op == 14 || op == 18 || op == 20 { out = out; }
 }
 out
}
