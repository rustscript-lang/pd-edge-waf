// Match fields: id, score, disruptive, status, skip-after, message.
fn record(state: map<string>, matched: [string]) -> map<string> {
    let mut s = state;
    let phase = number(ctx_get(&s, "phase"), 1);
    if number((&matched)[0], -1) >= 0 {
        let existing = ctx_get(&s, "matched_ids");
        s["matched_ids"] = if existing == "" => { (&matched)[0] } else => { existing + "," + (&matched)[0] };
    }
    if (&matched)[5] != "" {
        s["messages"] = ctx_get(&s, "messages") + (&matched)[5] + "\n";
    }
    let key = if phase <= 2 => { "score" } else => { "outbound_score" };
    let total = number(ctx_get(&s, key), 0) + number((&matched)[1], 0);
    s[key] = total + "";
    if phase <= 2 {
        s["tx.inbound_anomaly_score"] = total + "";
    } else {
        s["tx.outbound_anomaly_score"] = total + "";
    }
    if (&matched)[2] == "1" || (phase <= 2 && total >= 5) || (phase > 2 && total >= 4) {
        s["blocked"] = "1";
        s["status"] = (&matched)[3];
    }
    if (&matched)[4] != "" {
        s["skip"] = (&matched)[4];
    }
    s
}

// Rule fields: kind, id, phase, chain index, has-chain, targets, operator,
// pattern, transforms, paranoia, score, disruptive, status, skip-after, message.
pub fn apply_rule(state: map<string>, rule: [string]) -> map<string> {
    let mut s = state;
    let id = number((&rule)[1], -1);
    let phase = number((&rule)[2], 0);
    let chain_index = number((&rule)[3], 0);
    let current_user = number(ctx_get(&s, "phase"), 1);
    let skip_state = ctx_get(&s, "skip");
    if (phase == 0 || phase == current_user) && number((&rule)[9], 0) <= number(ctx_get(&s, "paranoia"), 1) && skip_state == "" {
    let mut matched = false;
    if chain_index == 0 || ctx_get(&s, "chain_matched") == "1" {
        let values: [string] = ctx_targets(&s, (&rule)[5], id);
        for i in 0..values.length {
            let transformed: string = transforms((&values)[i], (&rule)[8]);
            if op_matches(&s, (&rule)[6], (&rule)[7], transformed) {
                matched = true;
                break;
            }
        }
    }
    if chain_index == 0 && (&rule)[4] == "1" {
        s["chain_active"] = "1";
        s["chain_matched"] = if matched => { "1" } else => { "0" };
        s["chain_id"] = id + "";
        s["chain_score"] = (&rule)[10];
        s["chain_disruptive"] = (&rule)[11];
        s["chain_status"] = (&rule)[12];
        s["chain_skip"] = (&rule)[13];
        s["chain_message"] = (&rule)[14];
    } else if chain_index > 0 {
        let ok = ctx_get(&s, "chain_matched") == "1" && matched;
        s["chain_matched"] = if ok => { "1" } else => { "0" };
        if (&rule)[4] != "1" {
            if ctx_get(&s, "chain_active") == "1" && ok {
                s = record(s, [
                    ctx_get(&s, "chain_id"),
                    ctx_get(&s, "chain_score"),
                    ctx_get(&s, "chain_disruptive"),
                    ctx_get(&s, "chain_status"),
                    ctx_get(&s, "chain_skip"),
                    ctx_get(&s, "chain_message")
                ]);
            }
            s["chain_active"] = "0";
            s["chain_matched"] = "0";
        }
    } else if matched {
        s = record(s, [(&rule)[1], (&rule)[10], (&rule)[11], (&rule)[12], (&rule)[13], (&rule)[14]]);
    }
    }
    s
}

pub fn category_enabled(state: map<string>, category: string) -> bool {
    let enabled = ctx_get(&state, "enabled_ruleset");
    ctx_get(&state, "blocked") != "1" && (enabled == "" || contains(" " + enabled + " ", " " + category + " "))
}

