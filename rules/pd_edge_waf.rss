    next = set_phase(next, 1);
    if category_enabled(&next, "request_911_method_enforcement") { next = evaluate_request_911_method_enforcement(next); }
    if category_enabled(&next, "request_942_application_attack_sqli") { next = evaluate_request_942_application_attack_sqli(next); }
    next = set_phase(next, 2);
    if category_enabled(&next, "request_911_method_enforcement") { next = evaluate_request_911_method_enforcement(next); }
    if category_enabled(&next, "request_942_application_attack_sqli") { next = evaluate_request_942_application_attack_sqli(next); }
    next
}

pub fn inspect_response(state: map<string>) -> map<string> {
    let mut next = state;
    next = set_phase(next, 3);
    next = set_phase(next, 4);
    next = set_phase(next, 5);
    next
}

pub fn inspect(state: map<string>) -> map<string> {
    inspect_response(inspect_request(state))
}

let request_headers: map<string> = http::request::get_headers();
let request_args: map<string> = http::request::get_query_args();
let mut state: map<string> = new_state(
