pub fn starts(value: string, prefix: string) -> bool { prefix.length <= value.length && string_contains(&value, &prefix) && (&value)[0:prefix.length] == prefix }
pub fn ends(value: string, suffix: string) -> bool { suffix.length <= value.length && string_contains(&value, &suffix) && (&value)[(value.length - suffix.length):value.length] == suffix }
pub fn number(value: string, fallback: int) -> int {
 let digits = "0123456789"; let mut out = 0; let mut valid = value.length > 0;
 for i in 0..value.length { let ch = (&value)[i:(i + 1)]; let mut digit = -1; for j in 0..10 { if ch == (&digits)[j:(j + 1)] { digit = j; break; } } if digit < 0 { valid = false; break; } out = out * 10 + digit; }
 if valid => { out } else => { fallback }
}
pub fn encode_map(values: map<string>) -> string {
 let keys = (&values).keys; let mut out = "";
 for i in 0..keys.length { let key: string = (&keys)[i]; out = out + key + "=" + (&values)[key] + "\n"; }
 out
}
fn transforms_generic(value: string, encoded: int) -> string {
 let mut out: string = value;
 let mut plan: int = encoded;
  while plan > 0 {
   let op = plan % 32;
   plan = plan / 32;
   if op == 4 || op == 8 || op == 19 {
    if string_contains(&out, "%") || string_contains(&out, "+") {
     out = string_replace_literal(out, "%27", "'");
     out = string_replace_literal(out, "%22", "\"");
     out = string_replace_literal(out, "%20", " ");
     out = string_replace_literal(out, "%3d", "=");
     out = string_replace_literal(out, "%3D", "=");
     out = string_replace_literal(out, "%3c", "<");
     out = string_replace_literal(out, "%3C", "<");
     out = string_replace_literal(out, "%3e", ">");
     out = string_replace_literal(out, "%3E", ">");
     out = string_replace_literal(out, "+", " ");
    }
   }
   else if op == 7 { if string_contains(&out, "&") { out = string_replace_literal(out, "&lt;", "<"); out = string_replace_literal(out, "&gt;", ">"); out = string_replace_literal(out, "&quot;", "\""); out = string_replace_literal(out, "&#39;", "'"); } }
   else if op == 15 { if string_contains(&out, "\0") { out = string_replace_literal(out, "\0", ""); } }
   else if op == 16 { out = re::replace("\\s+", out, ""); }
   else if op == 3 { out = re::replace("\\s+", out, " "); }
   else if op == 17 { if string_contains(&out, "/*") { out = re::replace("(?s)/\\*.*?\\*/", out, " "); } }
   else if op == 12 || op == 13 { if string_contains(&out, "\\") { out = string_replace_literal(out, "\\", "/"); } }
   else if op == 2 { if string_contains(&out, "\\") { out = string_replace_literal(out, "\\", ""); } out = string_lower_ascii(out); }
   else if op == 10 { out = string_lower_ascii(out); }
   else if op == 9 { out = out.length + ""; }
   else if op == 1 || op == 5 || op == 6 || op == 11 || op == 14 || op == 18 || op == 20 { out = out; }
  }
 out
}
pub fn transforms(value: string, encoded: int) -> string {
 if encoded == 0 || encoded == 11 || encoded == 171 => { value }
 else if encoded == 10 || encoded == 331 => { string_lower_ascii(value) }
 else => { transforms_generic(value, encoded) }
}

