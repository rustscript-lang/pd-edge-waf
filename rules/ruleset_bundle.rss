// bundled from engine_text.rss

pub fn starts(value: string, prefix: string) -> bool { prefix.length <= value.length && string_contains(&value, &prefix) && (&value)[0:prefix.length] == prefix }
pub fn ends(value: string, suffix: string) -> bool { suffix.length <= value.length && string_contains(&value, &suffix) && (&value)[(value.length - suffix.length):value.length] == suffix }
pub fn number(value: string, fallback: int) -> int {
 let digits = "0123456789"; let mut out = 0; let mut valid = value.length > 0;
 for i in 0..value.length { let ch = (&value)[i:(i + 1)]; let mut digit = -1; for j in 0..10 { if ch == (&digits)[j:(j + 1)] { digit = j; break; } } if digit < 0 { valid = false; break; } out = out * 10 + digit; }
 if valid => { out } else => { fallback }
}
pub fn encode_map(values: map<string>) -> string {
 let keys = (&values).keys; let mut out = "";
 for i in 0..keys.length { let key: string = (&keys)[i]; out = out + key + "=" + (&values)[key] + "\n"; }
 out
}
fn transforms_generic(value: string, encoded: int) -> string {
 let mut out: string = value;
 let mut plan: int = encoded;
  while plan > 0 {
   let op = plan % 32;
   plan = plan / 32;
   if op == 4 || op == 8 || op == 19 {
    if string_contains(&out, "%") || string_contains(&out, "+") {
     out = string_replace_literal(out, "%27", "'");
     out = string_replace_literal(out, "%22", "\"");
     out = string_replace_literal(out, "%20", " ");
     out = string_replace_literal(out, "%3d", "=");
     out = string_replace_literal(out, "%3D", "=");
     out = string_replace_literal(out, "%3c", "<");
     out = string_replace_literal(out, "%3C", "<");
     out = string_replace_literal(out, "%3e", ">");
     out = string_replace_literal(out, "%3E", ">");
     out = string_replace_literal(out, "+", " ");
    }
   }
   else if op == 7 { if string_contains(&out, "&") { out = string_replace_literal(out, "&lt;", "<"); out = string_replace_literal(out, "&gt;", ">"); out = string_replace_literal(out, "&quot;", "\""); out = string_replace_literal(out, "&#39;", "'"); } }
   else if op == 15 { if string_contains(&out, "\0") { out = string_replace_literal(out, "\0", ""); } }
   else if op == 16 { out = re::replace("\\s+", out, ""); }
   else if op == 3 { out = re::replace("\\s+", out, " "); }
   else if op == 17 { if string_contains(&out, "/*") { out = re::replace("(?s)/\\*.*?\\*/", out, " "); } }
   else if op == 12 || op == 13 { if string_contains(&out, "\\") { out = string_replace_literal(out, "\\", "/"); } }
   else if op == 2 { if string_contains(&out, "\\") { out = string_replace_literal(out, "\\", ""); } out = string_lower_ascii(out); }
   else if op == 10 { out = string_lower_ascii(out); }
   else if op == 9 { out = out.length + ""; }
   else if op == 1 || op == 5 || op == 6 || op == 11 || op == 14 || op == 18 || op == 20 { out = out; }
  }
 out
}
pub fn transforms(value: string, encoded: int) -> string {
 if encoded == 0 || encoded == 11 || encoded == 171 => { value }
 else if encoded == 10 || encoded == 331 => { string_lower_ascii(value) }
 else => { transforms_generic(value, encoded) }
}

// bundled from engine_context.rss

pub fn ctx_get(state: map<string>, key: string) -> string {
 if (&state).has(&key) => { (&state)[key] } else => { "" }
}
pub fn ctx_set_phase(state: map<string>, phase: int) -> map<string> {
 let mut s = state; s["phase"] = phase + ""; s["skip"] = ""; s["chain_active"] = "0"; s["chain_matched"] = "0"; s
}
pub fn normalized_target_base(raw: string) -> string {
 let positive: string = if starts(&raw, "!") => { (&raw)[1:raw.length] } else => { raw };
 if starts(&positive, "&") => { (&positive)[1:positive.length] } else => { positive }
}
pub fn selector_matches(selector: string, name: string) -> bool {
 selector == "" || string_lower_ascii(&name) == string_lower_ascii(&selector) || (selector.length > 2 && (&selector)[0:1] == "/" && re::match((&selector)[1:(selector.length - 1)], &name))
}
pub fn descriptor_excludes(text: [string], target_count: int, base: string, name: string) -> bool {
 let mut excluded: bool = false; let mut i: int = (target_count / 65536) % 64;
 while i < target_count % 64 { let position: int = 3 + i * 2; let excluded_base: string = (&text)[position]; let excluded_selector: string = (&text)[position + 1]; if excluded_base == base && (excluded_selector == "" || (name != "" && selector_matches(excluded_selector, name))) { excluded = true; break; } i = i + 1; }
 excluded
}
pub fn dynamic_descriptor_excludes(bases: [string], selectors: [string], base: string, name: string) -> bool {
 let mut excluded: bool = false; let mut i: int = 0;
 while i < bases.length && i < selectors.length { let excluded_base: string = (&bases)[i]; let excluded_selector: string = (&selectors)[i]; if excluded_base == base && (excluded_selector == "" || (name != "" && selector_matches(excluded_selector, name))) { excluded = true; break; } i = i + 1; }
 excluded
}
pub fn pair_values(encoded: string, selector: string, names: bool, text: [string], target_count: int, base: string, dynamic_bases: [string], dynamic_selectors: [string]) -> [string] {
 let mut out: [string] = [];
 if encoded != "" { let lines: [string] = string_split_literal(encoded, "\n");
  for i in 0..lines.length { let line: string = (&lines)[i]; let pieces: [string] = string_split_literal(line, "=");
   if pieces.length > 0 { let key: string = (&pieces)[0]; if selector_matches(selector, &key) && (target_count % 32768 < 16384 || !descriptor_excludes(&text, target_count, &base, &key)) && (dynamic_bases.length == 0 || !dynamic_descriptor_excludes(&dynamic_bases, &dynamic_selectors, &base, &key)) {
    if names { out[out.length] = key; }
    else { let mut value: string = if pieces.length > 1 => { (&pieces)[1] } else => { "" }; let mut piece_index: int = 2; while piece_index < pieces.length { value = value + "=" + (&pieces)[piece_index]; piece_index = piece_index + 1; } out[out.length] = value; }
   } }
  }
 }
 out
}

pub fn one(state: map<string>, base: string, name: string, text: [string], target_count: int, dynamic_bases: [string], dynamic_selectors: [string]) -> [string] {
 let mut out: [string] = [];
 if base == "REQUEST_METHOD" { out = [ctx_get(&state, "method")]; }
 else if base == "REQUEST_FILENAME" || base == "REQUEST_URI" || base == "REQUEST_URI_RAW" || base == "REQUEST_BASENAME" { out = [ctx_get(&state, "path")]; }
 else if base == "QUERY_STRING" { out = [ctx_get(&state, "query")]; }
 else if base == "REQUEST_BODY" || base == "XML" || base == "FILES" || base == "FILES_NAMES" || base == "MULTIPART_PART_HEADERS" { out = [ctx_get(&state, "request_body")]; }
 else if base == "REQUEST_BODY_LENGTH" { out = [ctx_get(&state, "request_body").length + ""]; }
 else if base == "REQBODY_PROCESSOR" { out = [ctx_get(&state, "reqbody_processor")]; }
 else if base == "REQBODY_ERROR" { out = [ctx_get(&state, "reqbody_error")]; }
 else if base == "MULTIPART_STRICT_ERROR" { out = [ctx_get(&state, "multipart_strict_error")]; }
 else if base == "MULTIPART_UNMATCHED_BOUNDARY" { out = [ctx_get(&state, "multipart_unmatched_boundary")]; }
 else if base == "REQUEST_PROTOCOL" { out = [ctx_get(&state, "protocol")]; }
 else if base == "REQUEST_LINE" { out = [ctx_get(&state, "method") + " " + ctx_get(&state, "path") + (if ctx_get(&state, "query") == "" => { "" } else => { "?" + ctx_get(&state, "query") }) + " " + ctx_get(&state, "protocol")]; }
 else if base == "REMOTE_ADDR" { out = [ctx_get(&state, "client_ip")]; }
 else if base == "REQUEST_HEADERS" { out = pair_values(ctx_get(&state, "request_headers"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "REQUEST_HEADERS_NAMES" { out = pair_values(ctx_get(&state, "request_headers"), name, true, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "REQUEST_COOKIES" { out = pair_values(ctx_get(&state, "cookies"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "REQUEST_COOKIES_NAMES" { out = pair_values(ctx_get(&state, "cookies"), name, true, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "ARGS" || base == "ARGS_GET" { out = pair_values(ctx_get(&state, "args"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "ARGS_NAMES" || base == "ARGS_GET_NAMES" { out = pair_values(ctx_get(&state, "args"), name, true, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "RESPONSE_BODY" { out = [ctx_get(&state, "response_body")]; }
 else if base == "RESPONSE_STATUS" { out = [ctx_get(&state, "response_status")]; }
 else if base == "RESPONSE_HEADERS" { out = pair_values(ctx_get(&state, "response_headers"), name, false, &text, target_count, &base, &dynamic_bases, &dynamic_selectors); }
 else if base == "TX" { let tx_key: string = "tx." + string_lower_ascii(&name); if !starts(&name, "/") && (&state).has(&tx_key) { out = [(&state)[tx_key]]; } }
 out
}


pub fn ctx_targets(state: map<string>, text: [string], target_count: int, id: int) -> [string] {
 let mut out: [string] = []; let has_dynamic: bool = (&state).has(&("exclude_base." + id)); let encoded_bases: string = if has_dynamic => { (&state)["exclude_base." + id] } else => { "" }; let encoded_selectors: string = if has_dynamic => { ctx_get(&state, "exclude_selector." + id) } else => { "" }; let dynamic_bases: [string] = if has_dynamic => { string_split_literal(encoded_bases, "\n") } else => { [] }; let dynamic_selectors: [string] = if has_dynamic => { string_split_literal(encoded_selectors, "\n") } else => { [] }; let mut i: int = 0;
 while i < (if target_count % 32768 < 16384 => { target_count % 64 } else => { (target_count / 65536) % 64 }) { let position: int = 3 + i * 2; let raw_base: string = (&text)[position]; let name: string = (&text)[position + 1]; if (target_count % 32768 < 16384 || !descriptor_excludes(&text, target_count, &raw_base, &name)) && (!has_dynamic || !dynamic_descriptor_excludes(&dynamic_bases, &dynamic_selectors, &raw_base, &name)) { let values: [string] = one(&state, raw_base, name, &text, target_count, &dynamic_bases, &dynamic_selectors); if (target_count / 32768) % 2 == 0 || i < (target_count / 4194304) % 64 { for j in 0..values.length { out[out.length] = (&values)[j]; } } else { out[out.length] = values.length + ""; } } i = i + 1; }
 out
}
pub fn ctx_update(state: map<string>, id: int, raw_base: string, selector: string) -> map<string> {
 let mut s = state; let id_text: string = id + ""; let base_key: string = "exclude_base." + id_text; let selector_key: string = "exclude_selector." + id_text;
 s["has_dynamic_exclusions"] = "1";
 s[base_key] = ctx_get(&s, &base_key) + "\n" + normalized_target_base(raw_base) + "\n";
 s[selector_key] = ctx_get(&s, &selector_key) + "\n" + selector + "\n";
 s
}

// bundled from engine_operators.rss
pub fn op_expand(state: map<string>, value: string) -> string {
 let mut out: string = value;
 if string_contains(&out, "%{") { let keys: [string] = (&state).keys; for i in 0..keys.length { let key: string = (&keys)[i]; if starts(&key, "tx.") { out = string_replace_literal(out, "%{" + key + "}", (&state)[key]); } } }
 out
}
pub fn sqli(value: string) -> bool { let text: string = string_lower_ascii(value); (string_contains(&text, " union ") && string_contains(&text, "select")) || string_contains(&text, "' or '") || string_contains(&text, "'or 1=1") || string_contains(&text, " or 1=1") || string_contains(&text, "sleep(") || string_contains(&text, "benchmark(") || string_contains(&text, "information_schema") }

pub fn phrase(pattern: string, value: string) -> bool { let phrases: [string] = if string_contains(&pattern, "\n") => { string_split_literal(pattern, "\n") } else => { string_split_literal(pattern, " ") }; let haystack: string = string_lower_ascii(value); let mut found = false; for i in 0..phrases.length { let item: string = string_lower_ascii((&phrases)[i]); if item != "" && string_contains(&haystack, item) { found = true; break; } } found }
pub fn op_matches(state: map<string>, operator: int, argument: string, value: string) -> bool {
 let expected = if operator >= 128 => { operator = operator - 128; if (&state).has(&argument) => { "." + (&state)[argument] } else => { ".%{" + argument + "}" } } else if operator >= 64 => { operator = operator - 64; if (&state).has(&argument) => { (&state)[argument] } else => { "%{" + argument + "}" } } else => { op_expand(&state, argument) }; let negated: bool = operator >= 32; let code: int = if negated => { operator - 32 } else => { operator }; let mut raw: bool = false;
 if code == 1 { raw = re::match(&expected, &value); }
 else if code == 2 { raw = phrase(&expected, &value); }
 else if code == 3 { raw = sqli(&value); }
 else if code == 4 { let text: string = string_lower_ascii(value); raw = string_contains(&text, "<script") || string_contains(&text, "javascript:") || string_contains(&text, "onerror=") || string_contains(&text, "onload=") || (string_contains(&text, "<svg") && string_contains(&text, "on")); }
 else if code == 5 { raw = string_contains(&value, &expected); }
 else if code == 6 { raw = starts(&value, &expected); }
 else if code == 7 { raw = ends(&value, &expected); }
 else if code == 8 { raw = value == expected; }
 else if code == 9 { raw = string_contains(" " + expected + " ", " " + value + " "); }
 else if code == 10 { raw = number(&value, 0) == number(&expected, 0); }
 else if code == 11 { raw = number(&value, 0) < number(&expected, 0); }
 else if code == 12 { raw = number(&value, 0) >= number(&expected, 0); }
 else if code == 13 { raw = number(&value, 0) > number(&expected, 0); }
 else if code == 14 { raw = !re::match("%(?:[^0-9A-Fa-f]|.[^0-9A-Fa-f]|$)", &value); }
 else if code == 15 || code == 16 { raw = false; }
 else if code == 17 { raw = true; }
 else if code == 18 { raw = phrase(string_replace_literal(&expected, ",", "\n"), &value); }
 if negated => { !raw } else => { raw }
}

