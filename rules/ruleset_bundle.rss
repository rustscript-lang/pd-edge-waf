}
pub fn normalized_target_base(raw: string) -> string {
 let positive: string = if starts(&raw, "!") => { (&raw)[1:raw.length] } else => { raw };
 if starts(&positive, "&") => { (&positive)[1:positive.length] } else => { positive }
}
pub fn selector_matches(selector: string, name: string) -> bool {
 selector == "" || string_lower_ascii(&name) == string_lower_ascii(&selector) || (selector.length > 2 && (&selector)[0:1] == "/" && re::match((&selector)[1:(selector.length - 1)], &name))
}
pub fn descriptor_excludes(text: [string], target_count: int, base: string, name: string) -> bool {
 let mut excluded: bool = false; let mut i: int = (target_count / 65536) % 64;
 while i < target_count % 64 { let position: int = 3 + i * 2; let excluded_base: string = (&text)[position]; let excluded_selector: string = (&text)[position + 1]; if excluded_base == base && (excluded_selector == "" || (name != "" && selector_matches(excluded_selector, name))) { excluded = true; break; } i = i + 1; }
